Algorithme de calcule 
#calculer S=(a+b)*(a-c)
variables
        a=entier
        b=entier
        c=entier
        N:entier
        M:entier
  Debut
  #1 enregistrer les valeur des a,b et c  
      ecrire("donner une valeur de a":)
      lire(a)
      ecrire("donner une valeur de b":)
      lire(b)
      ecrire("donner une valeur de c":)
      lire(c)
  
  #2 faire du calcule
  
  
      N=a+b
      M=a-c
      S=N*M
      ecrire("resultat de S:",S)
      fin
